rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Default rule: By default, nobody can write. 
    // Public read is allowed for app assets like logos and user avatars.
    match /{allPaths=**} {
      allow read;
      allow write: if false;
    }

    // AVATARS
    // Users can only write to their own avatar folder.
    // Reading is public (covered by the rule above).
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // SCREENSHOTS
    // Users can only write payment screenshots to their own order folder.
    // Reading is public so admins can review them.
    match /screenshots/{userId}/{orderId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
