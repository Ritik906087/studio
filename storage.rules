rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // डिफ़ॉल्ट नियम: सुरक्षा के लिए सभी रीड और राइट को डिफ़ॉल्ट रूप से ब्लॉक करें।
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Avatars: कोई भी देख सकता है, लेकिन सिर्फ़ मालिक ही लिख सकता है।
    // इससे कोई भी प्रोफ़ाइल फ़ोटो देख सकता है, लेकिन केवल यूज़र ही अपनी फ़ोटो बदल सकता है।
    match /avatars/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Payment Proofs: यूज़र अपने ऑर्डर के लिए पेमेंट प्रूफ़ अपलोड कर सकता है, और एडमिन इसे पढ़ सकता है।
    match /payment_proofs/{userId}/{orderId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
