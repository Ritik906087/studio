rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access for all files.
    // This allows the app to display publicly stored images like logos and banners.
    match /{allPaths=**} {
      allow read;
    }

    // Allow authenticated users to write to their own avatar directory.
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to write payment screenshots to their own order directories.
    match /screenshots/{userId}/{orderId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
