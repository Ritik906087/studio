
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // WARNING: The following rules are simplified for prototyping and grant some public write access.
    // For a production app, you MUST use a secure backend and tighten these rules.

    match /users/{userId} {
      allow read: if true;
      allow write: if true; // More permissive for admin actions
    }
    
    match /users/{userId}/orders/{orderId} {
       allow read: if true;
       allow write: if true; // More permissive for admin actions
    }
    
    match /users/{userId}/sellOrders/{orderId} {
       allow read: if true;
       allow write: if true; // More permissive for admin actions
    }

    match /users/{userId}/transactions/{transactionId} {
       allow read, write: if request.auth.uid == userId;
    }
    
    match /users/{userId}/dailyRewards/{date} {
       allow read, write: if request.auth.uid == userId;
    }

    // Rules for top-level collections needed by admin panel
    match /paymentMethods/{methodId} {
      allow read: if true;
      allow write: if false; 
    }
    
    match /chatRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if true;
    }
    
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if true;
    }
    
    // Rules for Collection Group queries used in admin panel
    match /{path=**}/orders/{orderId} {
      allow read: if true;
    }
    match /{path=**}/sellOrders/{orderId} {
      allow read: if true;
    }
  }
}
