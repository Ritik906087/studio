
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // WARNING: The following rules grant public read access on several collections.
    // This is required for the admin panel to function without a proper backend.
    // For a production app, use a secure backend and tighten these rules.

    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /users/{userId}/orders/{orderId} {
       allow read: if true;
       allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /users/{userId}/sellOrders/{orderId} {
       allow read: if true;
       allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/transactions/{transactionId} {
       allow read: if true;
       allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /users/{userId}/dailyRewards/{date} {
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /paymentMethods/{methodId} {
      allow read: if true;
      allow write: if false; 
    }
    
    match /chatRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if true;
    }
  }
}
